# Operation Intelligence runtime configuration
# Spring Boot loads this file directly via OI_CONFIG_PATH.

server:
  port: 8096                            # env override: OI_PORT

spring:
  codec:
    max-in-memory-size: 10MB             # allow large knowledge graph JSON imports

operation-intelligence:
  secret-key: ""                        # env override: OI_SECRET_KEY [REQUIRED]
  cors-origin: "*"                      # env override: OI_CORS_ORIGIN

  # Optional: override data directory (defaults to ./data relative to config file)
  # Set to "../gateway" to reuse existing gateway/data/qos/ during migration
  # data-root: "../gateway"

  qos:
    enabled: true                             # enable health curve collection and API
    collection-interval-ms: 300000            # metrics collection interval (5 min)
    rotation-interval-ms: 3600000             # data file rotation interval (1 hour)
    raw-data-retention-days: 7
    detail-data-retention-days: 30
    normalize-data-retention-days: 90
    weights:
      availability: 0.4                       # wA (0~1, wA+wP+wR=1)
      performance: 0.4                        # wP
      resource: 0.2                           # wR
    dv-environments: []                        # DV environments, example:
    #  - env-code: "DigitalCRM.sit"
    #    env-name: "DigitalCRM SIT"
    #    agent-solution-type: "DigitalCRM"
    #    product-type-name: "DigitalCRM"
    #    server-url: "https://10.44.212.216:26335"
    #    utm-user: "admin"
    #    utm-password: "changeit"
    #    crt-content: ""                       # Base64 encoded certificate
    #    crt-file-name: "client.jks"
    #    strict-ssl: false                       # reject insecure SSL fallback (default: true)

  knowledge-graph:
    enabled: true                                # enable MVP knowledge graph import/query APIs
    data-dir: "knowledge-graph"                  # relative to operation-intelligence.data-root
    max-hops: 4                                  # maximum supported subgraph query hops
    snapshot-retention: 3                        # keep the latest N successful snapshots per environment

  logging:
    access-log-enabled: true

logging:
  level:
    root: INFO
    com.huawei.opsfactory.operationintelligence: INFO
    org.springframework: WARN
    reactor: WARN
    io.netty: WARN
